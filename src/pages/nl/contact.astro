---
import PageLayout from "../../layouts/PageLayout.astro";
import Icon from "../../components/ui/Icon.astro";
import { affiliates, founders } from "../../data/company";
import { site } from "../../data/site";
import { useTranslations } from "../../i18n/utils";
import { pickLocale } from "../../i18n/pickLocale";

const lang = "nl";
const t = useTranslations(lang);

const osmEmbedUrl = `https://www.openstreetmap.org/export/embed.html?bbox=${site.office.bbox[0]}%2C${site.office.bbox[1]}%2C${site.office.bbox[2]}%2C${site.office.bbox[3]}&layer=mapnik&marker=${site.office.lat}%2C${site.office.lon}`;
const mapsLink = `https://www.openstreetmap.org/?mlat=${site.office.lat}&mlon=${site.office.lon}#map=16/${site.office.lat}/${site.office.lon}`;

const createMailto = (recipient: string, subject: string, body: string) =>
  `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

const inquiryOptions = [
  {
    title: t('contact.inquiry.general.title'),
    description: t('contact.inquiry.general.description'),
    href: createMailto(
      site.contact.email,
      t('contact.inquiry.general.subject'),
      t('contact.inquiry.general.body')
    ),
    label: t('contact.inquiry.general.label'),
  },
  {
    title: t('contact.inquiry.advisory.title'),
    description: t('contact.inquiry.advisory.description'),
    href: createMailto(
      site.contact.email,
      t('contact.inquiry.advisory.subject'),
      t('contact.inquiry.advisory.body')
    ),
    label: t('contact.inquiry.advisory.label'),
  },
  {
    title: t('contact.inquiry.crisis.title'),
    description: t('contact.inquiry.crisis.description'),
    href: createMailto(
      founders[0].email,
      t('contact.inquiry.crisis.subject'),
      t('contact.inquiry.crisis.body')
    ),
    label: t('contact.inquiry.crisis.label'),
  },
  {
    title: t('contact.inquiry.academy.title'),
    description: t('contact.inquiry.academy.description'),
    href: createMailto(
      site.contact.email,
      t('contact.inquiry.academy.subject'),
      t('contact.inquiry.academy.body')
    ),
    label: t('contact.inquiry.academy.label'),
  },
];

const primaryInquiry = inquiryOptions[0];
const specializedInquiries = inquiryOptions.slice(1);
---

<PageLayout
  title="Contact"
  description="Contact Duke Strategies in 's-Hertogenbosch to discuss stakeholder strategy, corporate affairs, crisis communications, or Duke Academy."
  pathname="/nl/contact"
  ogImage="/assets/images/bridge-fog-water-minimalist.jpg"
  lang={lang}
>
  <section class="hero hero--short">
    <img src="/assets/images/bridge-fog-water-minimalist.jpg" alt="" class="hero__video" style="object-fit: cover;" aria-hidden="true" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <h1 class="hero-fade hero-fade-1">{t('contact.getInTouch')}</h1>
      <p class="hero__subtitle hero-fade hero-fade-2">
        {t('contact.heroSubtitle')}
      </p>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="7 13 12 18 17 13"></polyline>
        <line x1="12" y1="6" x2="12" y2="18"></line>
      </svg>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info animate">
          <span class="label">{t('contact.title')}</span>
          <h2>{site.legalName}</h2>
          <p class="contact-info__lede">
            {t('contact.lede')}
          </p>

          <div class="contact-info__block">
            <p>
              {site.office.street}<br />
              {site.office.postalCode} {site.office.city}<br />
              {site.office.country}
            </p>
          </div>

          <div class="contact-info__block">
            <a href={site.contact.phoneHref} class="contact-info__link">
              <Icon name="phone" />
              <span>T {site.contact.phoneDisplay}</span>
            </a>
            <a href={`mailto:${site.contact.email}`} class="contact-info__link">
              <Icon name="mail" />
              <span>{site.contact.email}</span>
            </a>
            <a href={site.contact.linkedin} target="_blank" rel="noopener noreferrer" class="contact-info__link">
              <Icon name="linkedin" />
              <span>linkedin.com/company/duke-strategies</span>
            </a>
          </div>

          <div class="contact-info__partners">
            <h4>{t('whoWeAre.foundingPartners')}</h4>
            {founders.map((founder) => (
              <div class="partner-entry">
                <div>
                  <strong>{founder.name}</strong>
                  <span>{pickLocale(founder.title, lang)}</span>
                </div>
                <a href={`mailto:${founder.email}`}>{founder.email}</a>
              </div>
            ))}
          </div>
        </div>

        <div class="animate stagger-2">
          <div class="contact-actions">
            <div class="contact-feature">
              <div class="contact-feature__copy">
                <span class="label">{t('contact.primaryRoute')}</span>
                <h3>{t('contact.primaryHeading')}</h3>
                <p>
                  {t('contact.primaryText')}
                </p>
              </div>

              <div class="contact-feature__actions">
                <a href={primaryInquiry.href} class="btn btn--primary">
                  {primaryInquiry.label}
                </a>
                <a href={site.contact.phoneHref} class="btn btn--outline">
                  {t('contact.callPhone')} {site.contact.phoneDisplay}
                </a>
              </div>
            </div>

            <div class="contact-actions__intro">
              <span class="label">{t('contact.emailOptions')}</span>
              <h3>{t('contact.emailOptionsHeading')}</h3>
              <p>
                {t('contact.emailOptionsText')}
              </p>
            </div>

            <div class="contact-actions__grid">
              {specializedInquiries.map((option, index) => (
                <article class={`contact-card animate stagger-${index + 2}`}>
                  <span class="contact-card__index">0{index + 1}</span>
                  <div class="contact-card__body">
                    <h4>{option.title}</h4>
                    <p>{option.description}</p>
                  </div>
                  <a href={option.href} class="btn btn--outline-dark">
                    {option.label}
                  </a>
                </article>
              ))}
            </div>

            <div class="contact-note">
              <p>
                {t('contact.blankDraft')} <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>. {t('contact.urgentCall')} <a href={site.contact.phoneHref}>{site.contact.phoneDisplay}</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">{t('contact.office')}</span>
      <h2 class="section-heading animate stagger-1">{t('contact.office')}</h2>

      <div class="map-embed animate stagger-2">
        <iframe
          src={osmEmbedUrl}
          title="Duke Strategies kantoorlocatie"
          loading="lazy"
          referrerpolicy="no-referrer"
        ></iframe>
        <div class="map-embed__card">
          <p class="map-embed__address">
            {site.office.street}<br />
            {site.office.postalCode} {site.office.city}<br />
            {site.office.country}
          </p>
          <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="map-embed__link">
            {t('contact.viewMap')} &rarr;
          </a>
        </div>
      </div>

      <div class="location-info animate stagger-3">
        <p>
          {t('contact.location.based')} <strong>{site.office.city}</strong>{t('contact.location.text')}
        </p>
        <p>
          {t('contact.location.affiliates')} <strong>{t('contact.location.affiliatesStrong')}</strong> {t('contact.location.affiliatesText')}
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">{t('whoWeAre.affiliates')}</span>
      <h2 class="section-heading animate stagger-1">{t('contact.globalReach')}</h2>

      <div class="affiliate-grid">
        {affiliates.map((affiliate, index) => (
          <div class={`affiliate-card animate stagger-${index + 2}`}>
            <h4>{affiliate.name}</h4>
            <p>{pickLocale(affiliate.description, lang)}</p>
            <a href={affiliate.href} target="_blank" rel="noopener noreferrer" class="btn btn--text">
              {affiliate.href.replace("https://", "")}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(0, 1.35fr);
    gap: var(--sp-9);
    align-items: start;
  }

  .contact-info {
    background:
      linear-gradient(180deg, rgba(255, 127, 102, 0.12) 0%, rgba(255, 127, 102, 0.02) 100%),
      linear-gradient(135deg, #242427 0%, #1c1c1e 62%, #171719 100%);
    border-radius: 4px;
    padding: var(--sp-7);
    box-shadow: var(--shadow-lg);
    position: sticky;
    top: calc(var(--nav-height) + var(--sp-4));
  }

  .contact-info h2 {
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.4;
    margin-bottom: var(--sp-4);
    color: var(--text-on-dark);
  }

  .contact-info :global(.label) {
    color: var(--accent);
  }

  .contact-info__lede {
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(223, 223, 224, 0.78);
    margin-bottom: var(--sp-6);
  }

  .contact-info__block {
    margin-bottom: var(--sp-5);
    padding-bottom: var(--sp-5);
    border-bottom: 1px solid rgba(223, 223, 224, 0.14);
  }

  .contact-info__block p {
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 0;
    color: rgba(223, 223, 224, 0.88);
  }

  .contact-info__link {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.95rem;
    margin-bottom: var(--sp-2);
    transition: color var(--transition-fast);
  }

  .contact-info__link:hover {
    color: var(--accent);
  }

  .contact-info__link :global(.icon) {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--accent);
  }

  .contact-info__partners {
    margin-top: var(--sp-6);
    display: grid;
    gap: var(--sp-3);
  }

  .contact-info__partners h4 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-2);
    color: rgba(223, 223, 224, 0.78);
  }

  .partner-entry {
    display: grid;
    gap: var(--sp-2);
    padding: var(--sp-4);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
  }

  .partner-entry strong {
    font-weight: 600;
    color: var(--text-on-dark);
    font-size: 0.95rem;
    display: block;
  }

  .partner-entry span {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(223, 223, 224, 0.58);
  }

  .partner-entry a {
    font-size: 0.9rem;
    color: var(--accent);
    transition: color var(--transition-fast);
  }

  .partner-entry a:hover {
    color: var(--accent-hover);
  }

  .contact-actions {
    display: grid;
    gap: var(--sp-5);
  }

  .contact-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto;
    gap: var(--sp-6);
    padding: var(--sp-7);
    border-radius: 4px;
    background:
      radial-gradient(circle at top right, rgba(255, 127, 102, 0.18), transparent 34%),
      linear-gradient(135deg, #1c1c1e 0%, #232327 100%);
    box-shadow: var(--shadow-lg);
    align-items: center;
  }

  .contact-feature__copy :global(.label) {
    color: var(--accent);
  }

  .contact-feature__copy h3 {
    font-size: clamp(1.55rem, 2.5vw, 2.2rem);
    color: var(--text-on-dark);
    margin-bottom: var(--sp-3);
  }

  .contact-feature__copy p {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(223, 223, 224, 0.8);
    margin-bottom: 0;
    max-width: 42rem;
  }

  .contact-feature__actions {
    display: grid;
    gap: var(--sp-3);
    justify-items: start;
  }

  .contact-feature__actions .btn {
    min-width: 15.5rem;
    justify-content: center;
  }

  .contact-actions__intro {
    padding: 0 var(--sp-1);
  }

  .contact-actions__intro h3 {
    font-size: clamp(1.25rem, 1.9vw, 1.6rem);
    margin-bottom: var(--sp-2);
  }

  .contact-actions__intro p {
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 0;
    color: var(--text-body);
  }

  .contact-actions__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-5);
  }

  .contact-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-top: 3px solid var(--accent);
    border-radius: 4px;
    padding: var(--sp-6);
    box-shadow: var(--shadow-md);
    display: grid;
    gap: var(--sp-4);
    min-height: 100%;
  }

  .contact-card__index {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .contact-card__body {
    display: grid;
    gap: var(--sp-3);
    align-content: start;
  }

  .contact-card h4 {
    font-size: 1.08rem;
    margin-bottom: 0;
  }

  .contact-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0;
  }

  .contact-card .btn {
    justify-self: start;
  }

  .contact-card:last-child {
    grid-column: 1 / -1;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-5);
  }

  .contact-card:last-child .contact-card__body {
    max-width: 36rem;
  }

  .contact-note {
    padding: var(--sp-4) var(--sp-5);
    border-left: 2px solid rgba(255, 127, 102, 0.35);
    background: rgba(255, 127, 102, 0.05);
    border-radius: 3px;
  }

  .contact-note p {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 0;
    color: var(--text-body);
  }

  .contact-note a {
    color: var(--accent);
  }

  .contact-note a:hover {
    color: var(--accent-hover);
  }

  .map-embed {
    position: relative;
    border-radius: 3px;
    overflow: hidden;
    height: 400px;
  }

  .map-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    filter: grayscale(0.15) contrast(1.02);
  }

  .map-embed__card {
    position: absolute;
    bottom: var(--sp-5);
    left: var(--sp-5);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-radius: 3px;
    padding: var(--sp-4) var(--sp-5);
    box-shadow: var(--shadow-md);
    z-index: 1;
  }

  :global([data-theme="dark"]) .map-embed__card {
    background: rgba(28, 28, 30, 0.92);
  }

  .map-embed__address {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-heading);
    margin-bottom: var(--sp-2);
  }

  .map-embed__link {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    transition: color var(--transition-fast);
  }

  .map-embed__link:hover {
    color: var(--accent-hover);
  }

  .location-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-6);
  }

  .location-info p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .affiliate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  .affiliate-card {
    background: var(--surface-alt);
    border-radius: 3px;
    padding: var(--sp-7) var(--sp-6);
    border-top: 4px solid var(--accent);
    transition: box-shadow var(--transition-med);
  }

  .affiliate-card:hover {
    box-shadow: var(--shadow-md);
  }

  .affiliate-card h4 {
    font-size: 1.1rem;
    margin-bottom: var(--sp-4);
  }

  .affiliate-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--sp-4);
  }

  @media (max-width: 768px) {
    .contact-grid,
    .location-info,
    .affiliate-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      position: static;
    }

    .contact-feature {
      grid-template-columns: 1fr;
      padding: var(--sp-6);
    }

    .contact-feature__actions,
    .contact-actions__grid {
      grid-template-columns: 1fr;
    }

    .contact-feature__actions .btn {
      width: 100%;
      min-width: 0;
    }

    .contact-card:last-child {
      grid-column: auto;
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
