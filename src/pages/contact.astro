---
import PageLayout from "../layouts/PageLayout.astro";
import Icon from "../components/ui/Icon.astro";
import { affiliates, founders } from "../data/company";
import { site } from "../data/site";

const createMailto = (recipient: string, subject: string, body: string) =>
  `mailto:${recipient}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

const inquiryOptions = [
  {
    title: "General Enquiries",
    description: "Start a straightforward conversation with Duke Strategies about your situation, timeline, or scope.",
    href: createMailto(
      site.contact.email,
      "[Website] General Enquiry",
      `Hello Duke Strategies,

I would like to discuss:

Company:
Timeline:

Best regards,`
    ),
    label: "Open General Email",
  },
  {
    title: "Strategic Advisory",
    description: "Open a prefilled draft for stakeholder strategy, corporate affairs, issue management, or board-level advisory.",
    href: createMailto(
      site.contact.email,
      "[Website] Strategic Advisory",
      `Hello Duke Strategies,

We would like support with strategic advisory on:

Organization:
Context:
Timeline:

Best regards,`
    ),
    label: "Open Advisory Email",
  },
  {
    title: "Crisis & Media",
    description: "Use this route when the request is time-sensitive or tied to crisis communications, media positioning, or stakeholder pressure.",
    href: createMailto(
      founders[0].email,
      "[Urgent] Crisis or Media Support",
      `Hello Ingo,

We need urgent support regarding:

Organization:
Immediate issue:
Urgency / deadline:
Phone number:

Best regards,`
    ),
    label: "Open Urgent Email",
  },
  {
    title: "Duke Academy",
    description: "Contact Duke Strategies about executive training, stakeholder dialogue, media preparation, or a tailored academy program.",
    href: createMailto(
      site.contact.email,
      "[Website] Duke Academy",
      `Hello Duke Strategies,

We are interested in Duke Academy support for:

Team / organization:
Preferred program:
Expected participants:

Best regards,`
    ),
    label: "Open Academy Email",
  },
];

const primaryInquiry = inquiryOptions[0];
const specializedInquiries = inquiryOptions.slice(1);
---

<PageLayout
  title="Contact"
  description="Contact Duke Strategies in 's-Hertogenbosch to discuss stakeholder strategy, corporate affairs, crisis communications, or Duke Academy."
  pathname="/contact"
  ogImage="/assets/images/bridge-fog-water-minimalist.jpg"
>
  <section class="hero hero--short">
    <img src="/assets/images/bridge-fog-water-minimalist.jpg" alt="" class="hero__video" style="object-fit: cover;" aria-hidden="true" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <h1 class="hero-fade hero-fade-1">Get In Touch</h1>
      <p class="hero__subtitle hero-fade hero-fade-2">
        We'd love to hear from you. Reach out to discuss how Duke Strategies can help your organization.
      </p>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="7 13 12 18 17 13"></polyline>
        <line x1="12" y1="6" x2="12" y2="18"></line>
      </svg>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info animate">
          <span class="label">Contact Us</span>
          <h2>{site.legalName}</h2>
          <p class="contact-info__lede">
            A direct route into senior advisory, stakeholder strategy, crisis communications and Duke Academy programs.
          </p>

          <div class="contact-info__block">
            <p>
              {site.office.street}<br />
              {site.office.postalCode} {site.office.city}<br />
              {site.office.country}
            </p>
          </div>

          <div class="contact-info__block">
            <a href={site.contact.phoneHref} class="contact-info__link">
              <Icon name="phone" />
              <span>T {site.contact.phoneDisplay}</span>
            </a>
            <a href={`mailto:${site.contact.email}`} class="contact-info__link">
              <Icon name="mail" />
              <span>{site.contact.email}</span>
            </a>
            <a href={site.contact.linkedin} target="_blank" rel="noopener noreferrer" class="contact-info__link">
              <Icon name="linkedin" />
              <span>linkedin.com/company/duke-strategies</span>
            </a>
          </div>

          <div class="contact-info__partners">
            <h4>Founding Partners</h4>
            {founders.map((founder) => (
              <div class="partner-entry">
                <div>
                  <strong>{founder.name}</strong>
                  <span>{founder.title}</span>
                </div>
                <a href={`mailto:${founder.email}`}>{founder.email}</a>
              </div>
            ))}
          </div>
        </div>

        <div class="animate stagger-2">
          <div class="contact-actions">
            <div class="contact-feature">
              <div class="contact-feature__copy">
                <span class="label">Primary Route</span>
                <h3>Start with one clear email.</h3>
                <p>
                  The general mailbox is the simplest entry point. Use it for new mandates, introductions, or anything that does not yet need to be routed to a specialist thread.
                </p>
              </div>

              <div class="contact-feature__actions">
                <a href={primaryInquiry.href} class="btn btn--primary">
                  {primaryInquiry.label}
                </a>
                <a href={site.contact.phoneHref} class="btn btn--outline">
                  Call {site.contact.phoneDisplay}
                </a>
              </div>
            </div>

            <div class="contact-actions__intro">
              <span class="label">Email Options</span>
              <h3>Choose the quickest route into the conversation.</h3>
              <p>
                Each option below opens your default mail app with the recipient, subject line and draft structure already prepared.
              </p>
            </div>

            <div class="contact-actions__grid">
              {specializedInquiries.map((option, index) => (
                <article class={`contact-card animate stagger-${index + 2}`}>
                  <span class="contact-card__index">0{index + 1}</span>
                  <div class="contact-card__body">
                    <h4>{option.title}</h4>
                    <p>{option.description}</p>
                  </div>
                  <a href={option.href} class="btn btn--outline-dark">
                    {option.label}
                  </a>
                </article>
              ))}
            </div>

            <div class="contact-note">
              <p>
                Prefer a blank draft? Use <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>. If the matter is urgent, call <a href={site.contact.phoneHref}>{site.contact.phoneDisplay}</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">Find Us</span>
      <h2 class="section-heading animate stagger-1">Our Location</h2>

      <div class="map-placeholder animate stagger-2">
        <span class="map-placeholder__icon"><Icon name="map" /></span>
        <p class="map-placeholder__address">
          {site.office.street}<br />
          {site.office.postalCode} {site.office.city}<br />
          {site.office.country}
        </p>
        <span class="map-placeholder__text">Map loading...</span>
      </div>

      <div class="location-info animate stagger-3">
        <p>
          Based in <strong>{site.office.city}</strong>, the Netherlands - at the crossroads of strategy, stakeholders and communications.
        </p>
        <p>
          With <strong>international affiliates</strong> in Scandinavia, the UK, the US and Germany - ensuring global reach with local expertise.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">International Network</span>
      <h2 class="section-heading animate stagger-1">Global Reach</h2>

      <div class="affiliate-grid">
        {affiliates.map((affiliate, index) => (
          <div class={`affiliate-card animate stagger-${index + 2}`}>
            <h4>{affiliate.name}</h4>
            <p>{affiliate.description}</p>
            <a href={affiliate.href} target="_blank" rel="noopener noreferrer" class="btn btn--text">
              {affiliate.href.replace("https://", "")}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(0, 1.35fr);
    gap: var(--sp-9);
    align-items: start;
  }

  .contact-info {
    background:
      linear-gradient(180deg, rgba(255, 127, 102, 0.12) 0%, rgba(255, 127, 102, 0.02) 100%),
      linear-gradient(135deg, #242427 0%, #1c1c1e 62%, #171719 100%);
    border-radius: 4px;
    padding: var(--sp-7);
    box-shadow: var(--shadow-lg);
    position: sticky;
    top: calc(var(--nav-height) + var(--sp-4));
  }

  .contact-info h2 {
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.4;
    margin-bottom: var(--sp-4);
    color: var(--text-on-dark);
  }

  .contact-info :global(.label) {
    color: var(--accent);
  }

  .contact-info__lede {
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(223, 223, 224, 0.78);
    margin-bottom: var(--sp-6);
  }

  .contact-info__block {
    margin-bottom: var(--sp-5);
    padding-bottom: var(--sp-5);
    border-bottom: 1px solid rgba(223, 223, 224, 0.14);
  }

  .contact-info__block p {
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 0;
    color: rgba(223, 223, 224, 0.88);
  }

  .contact-info__link {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: 0.95rem;
    margin-bottom: var(--sp-2);
    transition: color var(--transition-fast);
  }

  .contact-info__link:hover {
    color: var(--accent);
  }

  .contact-info__link :global(.icon) {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--accent);
  }

  .contact-info__partners {
    margin-top: var(--sp-6);
    display: grid;
    gap: var(--sp-3);
  }

  .contact-info__partners h4 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-2);
    color: rgba(223, 223, 224, 0.78);
  }

  .partner-entry {
    display: grid;
    gap: var(--sp-2);
    padding: var(--sp-4);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
  }

  .partner-entry strong {
    font-weight: 600;
    color: var(--text-on-dark);
    font-size: 0.95rem;
    display: block;
  }

  .partner-entry span {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(223, 223, 224, 0.58);
  }

  .partner-entry a {
    font-size: 0.9rem;
    color: var(--accent);
    transition: color var(--transition-fast);
  }

  .partner-entry a:hover {
    color: var(--accent-hover);
  }

  .contact-actions {
    display: grid;
    gap: var(--sp-5);
  }

  .contact-feature {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) auto;
    gap: var(--sp-6);
    padding: var(--sp-7);
    border-radius: 4px;
    background:
      radial-gradient(circle at top right, rgba(255, 127, 102, 0.18), transparent 34%),
      linear-gradient(135deg, #1c1c1e 0%, #232327 100%);
    box-shadow: var(--shadow-lg);
    align-items: center;
  }

  .contact-feature__copy :global(.label) {
    color: var(--accent);
  }

  .contact-feature__copy h3 {
    font-size: clamp(1.55rem, 2.5vw, 2.2rem);
    color: var(--text-on-dark);
    margin-bottom: var(--sp-3);
  }

  .contact-feature__copy p {
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(223, 223, 224, 0.8);
    margin-bottom: 0;
    max-width: 42rem;
  }

  .contact-feature__actions {
    display: grid;
    gap: var(--sp-3);
    justify-items: start;
  }

  .contact-feature__actions .btn {
    min-width: 15.5rem;
    justify-content: center;
  }

  .contact-actions__intro {
    padding: 0 var(--sp-1);
  }

  .contact-actions__intro h3 {
    font-size: clamp(1.25rem, 1.9vw, 1.6rem);
    margin-bottom: var(--sp-2);
  }

  .contact-actions__intro p {
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 0;
    color: var(--text-body);
  }

  .contact-actions__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-5);
  }

  .contact-card {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 243, 240, 0.96) 100%);
    border-top: 3px solid var(--accent);
    border-radius: 4px;
    padding: var(--sp-6);
    box-shadow: 0 18px 40px rgba(28, 28, 30, 0.08);
    display: grid;
    gap: var(--sp-4);
    min-height: 100%;
  }

  .contact-card__index {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .contact-card__body {
    display: grid;
    gap: var(--sp-3);
    align-content: start;
  }

  .contact-card h4 {
    font-size: 1.08rem;
    margin-bottom: 0;
  }

  .contact-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 0;
  }

  .contact-card .btn {
    justify-self: start;
  }

  .contact-card:last-child {
    grid-column: 1 / -1;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--sp-5);
  }

  .contact-card:last-child .contact-card__body {
    max-width: 36rem;
  }

  .contact-note {
    padding: var(--sp-4) var(--sp-5);
    border-left: 2px solid rgba(255, 127, 102, 0.35);
    background: rgba(255, 127, 102, 0.05);
    border-radius: 3px;
  }

  .contact-note p {
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 0;
    color: var(--text-body);
  }

  .contact-note a {
    color: var(--accent);
  }

  .contact-note a:hover {
    color: var(--accent-hover);
  }

  .map-placeholder {
    background: var(--rule);
    border-radius: 3px;
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: var(--sp-3);
    position: relative;
    overflow: hidden;
  }

  .map-placeholder::before {
    content: "";
    position: absolute;
    inset: 0;
    border: 2px solid rgba(255, 127, 102, 0.2);
    border-radius: 3px;
    pointer-events: none;
  }

  .map-placeholder__icon {
    width: 48px;
    height: 48px;
    color: var(--accent);
    opacity: 0.6;
    font-size: 3rem;
  }

  .map-placeholder__text {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-body);
    opacity: 0.6;
  }

  .map-placeholder__address {
    font-size: 0.9rem;
    color: var(--text-heading);
    text-align: center;
    line-height: 1.7;
  }

  .location-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-6);
  }

  .location-info p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .affiliate-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  .affiliate-card {
    background: var(--surface-alt);
    border-radius: 3px;
    padding: var(--sp-7) var(--sp-6);
    border-top: 4px solid var(--accent);
    transition: box-shadow var(--transition-med);
  }

  .affiliate-card:hover {
    box-shadow: var(--shadow-md);
  }

  .affiliate-card h4 {
    font-size: 1.1rem;
    margin-bottom: var(--sp-4);
  }

  .affiliate-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--sp-4);
  }

  .form-note {
    margin-top: var(--sp-3);
    font-size: 0.8rem;
    color: var(--text-body);
    opacity: 0.75;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .contact-grid,
    .location-info,
    .affiliate-grid {
      grid-template-columns: 1fr;
    }

    .contact-info {
      position: static;
    }

    .contact-feature {
      grid-template-columns: 1fr;
      padding: var(--sp-6);
    }

    .contact-feature__actions,
    .contact-actions__grid {
      grid-template-columns: 1fr;
    }

    .contact-feature__actions .btn {
      width: 100%;
      min-width: 0;
    }

    .contact-card:last-child {
      grid-column: auto;
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
