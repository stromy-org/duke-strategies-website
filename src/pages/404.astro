---
import BaseLayout from "../layouts/BaseLayout.astro";
import { notFound } from "../data/content/notFound";
---

<BaseLayout title={notFound.title} pathname="/404" noIndex={true}>
  <main style="padding: 6rem 1.5rem; max-width: 48rem; margin: 0 auto;">
    <h1>404</h1>
    <p>{notFound.bodyEn}</p>
    <p>{notFound.bodyNl}</p>
    <p>
      <a href="/en/">{notFound.homeEn}</a> · <a href="/nl/">{notFound.homeNl}</a>
    </p>
  </main>
</BaseLayout>
