---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" pathname="/404" noIndex={true}>
  <main style="padding: 6rem 1.5rem; max-width: 48rem; margin: 0 auto;">
    <h1>404</h1>
    <p>The page you requested could not be found.</p>
    <p>Deze pagina bestaat niet (meer).</p>
    <p>
      <a href="/en/">Return home</a> · <a href="/nl/">Terug naar home</a>
    </p>
  </main>
</BaseLayout>
