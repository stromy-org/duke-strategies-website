---
import PageLayout from "../layouts/PageLayout.astro";
import CTABand from "../components/ui/CTABand.astro";
import Icon from "../components/ui/Icon.astro";
import ProgramCard from "../components/ui/ProgramCard.astro";
import { academyPrograms } from "../data/company";
---

<PageLayout
  title="Duke Academy"
  description="Duke Academy is Duke Strategies' AI-powered executive training branch for high-stakes communication, stakeholder dialogue, and strategic leadership."
  pathname="/duke-academy"
  ogImage="/assets/images/Pythonbrug_Amsterdam_contrast.jpg"
>
  <section class="hero hero--academy">
    <img src="/assets/images/Pythonbrug_Amsterdam_contrast.jpg" alt="" class="hero__bg" aria-hidden="true" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <img
        src="/assets/logos/DukeAcademy_rgb_no_padding.svg"
        alt="Duke Academy"
        class="hero__academy-logo hero-fade hero-fade-1"
      />
      <h1 class="hero-fade hero-fade-2">AI-Powered Executive Training for Impactful Leadership</h1>
      <p class="hero__subtitle hero-fade hero-fade-3">
        Duke Academy is Duke Strategies' executive training and development branch.
      </p>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="7 13 12 18 17 13"></polyline>
        <line x1="12" y1="6" x2="12" y2="18"></line>
      </svg>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">Duke Academy</span>
      <h2 class="section-heading animate stagger-1">Training that makes a difference</h2>

      <div class="grid grid--7-5 items-start" style="margin-top: var(--sp-6);">
        <div class="animate stagger-2">
          <p>
            Duke Academy is Duke Strategies' executive training and development branch. We help executives convey their strategic decisions with clarity and connect impactfully with stakeholders.
          </p>
          <p>
            Strategic decisions only make a difference when communicated with conviction. Duke Academy is one of the first AI-supported executive training programs in the Netherlands, designed for leaders who need to connect with investors, regulators, employees and the public.
          </p>
        </div>
        <div class="img-cover img-cover--coral animate stagger-3" style="min-height: 360px;">
          <img src="/assets/images/cable-bridge-golden-hour.jpg" alt="Bridge at golden hour" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">Our Approach</span>
      <h2 class="section-heading animate stagger-1">What Makes Duke Academy Unique?</h2>

      <div class="grid grid--7-5 items-start" style="margin-top: var(--sp-6);">
        <div class="animate stagger-2">
          <p>
            We combine high-level personal coaching with cutting-edge AI tools. Executives begin with focused half-day sessions to sharpen their message and delivery, then continue practicing with virtual stakeholders tailored to their strategic context.
          </p>
          <p>
            These AI tools simulate real-world reactions and provide instant feedback on tone, clarity, and persuasive power. We use AI as a partner, not a replacement.
          </p>
        </div>
        <div class="img-cover img-cover--coral animate stagger-3" style="min-height: 360px;">
          <img src="/assets/images/modern-cable-bridge-calm-water.jpg" alt="Modern bridge over calm water" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">Programs</span>
      <h2 class="section-heading animate stagger-1">Training Programs</h2>

      <div class="program-grid">
        {academyPrograms.map((program, index) => (
          <ProgramCard {...program} class={`animate stagger-${(index % 4) + 2}`} />
        ))}
      </div>

      <div class="program-note animate stagger-6">
        Each session is compact, designed for one to four participants, and followed by access to a personalised virtual practice environment.
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">Why Duke Academy</span>
      <h2 class="section-heading animate stagger-1">Why Choose Duke Academy?</h2>

      <div class="animate stagger-2" style="max-width: 720px;">
        <ul class="feature-list">
          <li><Icon name="check" /> AI-integrated executive coaching</li>
          <li><Icon name="check" /> Realistic simulations with custom-built virtual stakeholders</li>
          <li><Icon name="check" /> Deep insight into message reception and impact</li>
          <li><Icon name="check" /> Developed by Duke Strategies at the intersection of strategy and corporate affairs</li>
          <li><Icon name="check" /> Seasoned trainers with a combined experience of over 50 years</li>
        </ul>
      </div>
    </div>
  </section>

  <div class="result-banner">
    <img
      src="/assets/images/shutterstock_1510566293_RoyalWelshbrug_zwart_1920x1280px_dark.jpg"
      alt=""
      class="result-banner__bg"
      aria-hidden="true"
    />
    <div class="result-banner__overlay"></div>
    <div class="result-banner__content">
      <span class="label animate" style="color: var(--accent);">The Outcome</span>
      <h2 class="animate stagger-1">The Result</h2>
      <p class="animate stagger-2">
        Executives become more effective communicators in strategic settings. They learn to tailor their message to diverse audiences and boost their influence in critical conversations. Duke Academy helps leaders communicate with impact - coached by experienced trainers, powered by AI, focused on results.
      </p>
    </div>
  </div>

  <CTABand
    title="Want to know more?"
    description="Contact us to discuss how Duke Academy can help your leadership team."
  />
</PageLayout>

<style>
  .program-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  .program-note {
    margin-top: var(--sp-8);
    padding: var(--sp-6);
    background: rgba(255, 127, 102, 0.06);
    border-left: 4px solid var(--accent);
    border-radius: 3px;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .feature-list {
    list-style: none;
    margin: var(--sp-6) 0;
  }

  .feature-list li {
    padding: var(--sp-3) 0;
    display: flex;
    gap: var(--sp-3);
    align-items: flex-start;
    font-size: 1rem;
    line-height: 1.7;
  }

  .feature-list :global(.icon) {
    width: 22px;
    height: 22px;
    min-width: 22px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 0.75rem;
    margin-top: 0.15rem;
  }

  .result-banner {
    position: relative;
    min-height: 400px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .result-banner__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .result-banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(28, 28, 30, 0.75);
  }

  .result-banner__content {
    position: relative;
    z-index: 1;
    color: #fff;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--sp-10) var(--sp-5);
  }

  .result-banner__content h2 {
    color: #fff;
    margin-bottom: var(--sp-5);
  }

  .result-banner__content p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.05rem;
    line-height: 1.8;
    max-width: 720px;
  }

  @media (max-width: 768px) {
    .program-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
