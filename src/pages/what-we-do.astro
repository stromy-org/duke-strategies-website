---
import PageLayout from "../layouts/PageLayout.astro";
import CTABand from "../components/ui/CTABand.astro";
import Icon from "../components/ui/Icon.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import { capabilities, services } from "../data/company";
---

<PageLayout
  title="What We Do"
  description="Duke Strategies uses an Analyse, Create & Execute model to build stakeholder-proof strategy, narrative, and implementation."
  pathname="/what-we-do"
  ogImage="/assets/images/Nesciobrug.jpg"
>
  <section class="hero hero--page">
    <img src="/assets/images/Nesciobrug.jpg" alt="" class="hero__bg" aria-hidden="true" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <h1 class="hero-fade hero-fade-1">Corporate Strategy, Stakeholder Analysis &amp; Execution</h1>
      <p class="hero__subtitle hero-fade hero-fade-2">
        We use a three-step advisory model to understand stakeholder dynamics, develop strategy, and support implementation.
      </p>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="7 13 12 18 17 13"></polyline>
        <line x1="12" y1="6" x2="12" y2="18"></line>
      </svg>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">Our Model</span>
      <h2 class="section-heading animate stagger-1">Analyse, Create &amp; Execute</h2>
      <p class="animate stagger-2 max-w-lg" style="margin-bottom: var(--sp-8);">
        Duke Strategies uses a three-step advisory model to understand stakeholder dynamics, develop a corporate and communications strategy, and support impactful implementation.
      </p>

      <div class="ace-steps">
        <div class="ace-step animate stagger-2">
          <div class="ace-step__number">01</div>
          <div class="ace-step__body">
            <h3>Analyse</h3>
            <p>
              Our analyses include a deep understanding of our clients' strategic directions and the expectations of stakeholders. We analyse intent, capabilities and likely responses based on plans, interviews and advanced AI tools, then define the challenge the strategy must answer.
            </p>
          </div>
        </div>

        <div class="ace-step animate stagger-3">
          <div class="ace-step__number">02</div>
          <div class="ace-step__body">
            <h3>Create</h3>
            <p>
              We explore an overarching Single Most Important Action that should respond to the identified challenge. That action becomes the foundation for strategy, narrative, messaging, and stakeholder engagement.
            </p>
            <p>
              A strategy that cannot be communicated is a strategy that will not be executed. We work at the intersection of boardroom strategy and the storytelling needed to move people.
            </p>
          </div>
        </div>

        <div class="ace-step animate stagger-4">
          <div class="ace-step__number">03</div>
          <div class="ace-step__body">
            <h3>Execute</h3>
            <p>
              In the execution phase we help clients carry the plan into reality, whether the actions relate to business, governance, stakeholder dialogue, communications or public positioning.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">Capabilities</span>
      <h2 class="section-heading animate stagger-1">In the execution phase, we deploy our wealth of experience in:</h2>

      <div class="capabilities-grid">
        {capabilities.map((capability, index) => (
          <div class={`capability animate stagger-${(index % 6) + 1}`}>
            <div class="capability__icon">
              <Icon name={capability.icon} />
            </div>
            <div class="capability__title">{capability.title}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">Our Services</span>
      <h2 class="section-heading animate stagger-1">What We Do</h2>

      <div class="services-grid">
        {services.map((service, index) => (
          <ServiceCard {...service} class={`animate stagger-${(index % 6) + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title="Let's talk strategy"
    description="Get in touch with Duke Strategies to explore how we help business leaders manage stakeholder expectations, strategic change, and corporate affairs with confidence."
  />
</PageLayout>

<style>
  .ace-step {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--sp-6);
    align-items: start;
    padding: var(--sp-8) 0;
    border-bottom: 1px solid var(--rule);
    position: relative;
  }

  .ace-step:last-child {
    border-bottom: none;
  }

  .ace-step__number {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--accent);
    line-height: 1;
    opacity: 0.25;
  }

  .ace-step__body h3 {
    font-size: 1.25rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-4);
    color: var(--text-heading);
  }

  .ace-step__body p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-body);
  }

  .ace-steps {
    position: relative;
  }

  .ace-steps::before {
    content: "";
    position: absolute;
    left: 50px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    opacity: 0.15;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    margin-top: var(--sp-8);
  }

  .capability {
    text-align: center;
    padding: var(--sp-6) var(--sp-4);
    border-radius: 3px;
    transition: transform var(--transition-med), box-shadow var(--transition-med);
    background: var(--surface-page);
  }

  .capability:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-4px);
  }

  .capability__icon {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--sp-4);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 127, 102, 0.1);
    color: var(--accent);
    font-size: 1.4rem;
  }

  .capability__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-heading);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  @media (max-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .ace-step {
      grid-template-columns: 60px 1fr;
      gap: var(--sp-4);
    }

    .ace-steps::before {
      left: 30px;
    }
  }

  @media (max-width: 480px) {
    .capabilities-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
