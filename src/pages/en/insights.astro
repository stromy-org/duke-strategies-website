---
import PageLayout from "../../layouts/PageLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import CTABand from "../../components/ui/CTABand.astro";
import InsightCard from "../../components/ui/InsightCard.astro";
import Testimonial from "../../components/ui/Testimonial.astro";
import { caseStudies, insights, testimonials } from "../../data/company";
import { useTranslations } from "../../i18n/utils";
import { pickLocale } from "../../i18n/pickLocale";

const lang = "en";
const t = useTranslations(lang);
---

<PageLayout
  title="Insights & Case Studies"
  description="Real thinking from real engagements: Duke Strategies case studies, client outcomes, and thought leadership."
  pathname="/en/insights"
  ogImage="/assets/images/cable-bridge-dark-sky-dramatic.jpg"
  lang={lang}
>
  <section class="hero hero--short">
    <img src="/assets/images/cable-bridge-dark-sky-dramatic.jpg" alt="" class="hero__bg" aria-hidden="true" />
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <h1 class="hero-fade hero-fade-1">{t('insights.title')}</h1>
      <p class="hero__subtitle hero-fade hero-fade-2">
        {t('insights.heroSubtitle')}
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">{t('whatWeDo.caseStudies')}</span>

      {caseStudies.map((study, index) => (
        <div class="case-study">
          <div class:list={["grid", index % 2 === 0 ? "grid--7-5" : "grid--5-7", "items-start", "animate", "stagger-1"]}>
            {index % 2 === 1 && (
              <div class="img-cover img-cover--coral img-cover--wide">
                <img src={study.image} alt={pickLocale(study.imageAlt, lang)} />
              </div>
            )}

            <div>
              <Badge text={pickLocale(study.industry, lang)} class="case-study__pill" />
              <h3 class="case-study__title">{pickLocale(study.title, lang)}</h3>
              <p class="case-study__challenge">{pickLocale(study.challenge, lang)}</p>

              <div class:list={["case-metrics--row", `case-metrics--count-${study.metrics.length}`]}>
                {study.metrics.map((metric) => (
                  <div class="case-metric">
                    <span class="case-metric__value">{metric.value}</span>
                    <span class="case-metric__label">{pickLocale(metric.label, lang)}</span>
                  </div>
                ))}
              </div>

              {study.team && <p class="case-study__team"><strong>{t('insights.teamLabel')}</strong> {pickLocale(study.team!, lang)}</p>}
            </div>

            {index % 2 === 0 && (
              <div class="img-cover img-cover--coral img-cover--wide">
                <img src={study.image} alt={pickLocale(study.imageAlt, lang)} />
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">{t('whatWeDo.testimonials')}</span>
      <h2 class="section-heading animate stagger-1">{t('whatWeDo.testimonials')}</h2>

      <div class="testimonial-grid">
        {testimonials.map((testimonial, index) => (
          <Testimonial quote={pickLocale(testimonial.quote, lang)} author={pickLocale(testimonial.author, lang)} variant="card" class={`animate stagger-${(index % 4) + 2}`} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">{t('insights.thoughtLeadership')}</span>
      <h2 class="section-heading animate stagger-1">{t('insights.latestThinking')}</h2>
      <p class="animate stagger-2 max-w-lg" style="margin-bottom: var(--sp-6);">
        {t('insights.latestThinkingText')}
      </p>

      <div class="insights-grid">
        {insights.map((item, index) => (
          <InsightCard badge={pickLocale(item.badge, lang)} date={item.date} title={pickLocale(item.title, lang)} excerpt={pickLocale(item.excerpt, lang)} href={item.href} linkLabel={pickLocale(item.linkLabel, lang)} class={`animate stagger-${(index % 3) + 2}`} />
        ))}
      </div>
    </div>
  </section>

  <CTABand
    title={t('insights.cta.title')}
    description={t('insights.cta.description')}
    href="/en/contact"
    label={t('cta.button')}
  />
</PageLayout>

<style>
  .case-study {
    padding: var(--sp-9) 0;
  }

  .case-study:first-child {
    padding-top: 0;
  }

  .case-study + .case-study {
    border-top: 1px solid var(--rule);
  }

  .case-study__pill {
    margin-bottom: var(--sp-4);
  }

  .case-study__title {
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.3;
    margin-bottom: var(--sp-4);
  }

  .case-study__challenge {
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: var(--sp-5);
  }

  .case-study__team {
    font-size: 0.85rem;
    color: var(--text-body);
    margin-top: var(--sp-4);
  }

  .case-study__team strong {
    color: var(--text-heading);
  }

  .case-metrics--row {
    display: grid;
    gap: var(--sp-5) var(--sp-6);
    margin-top: var(--sp-5);
    padding: var(--sp-5) var(--sp-6);
    background: var(--surface-alt);
    border-radius: 3px;
    border-left: 4px solid var(--accent);
  }
  .case-metrics--count-2 { grid-template-columns: repeat(2, 1fr); }
  .case-metrics--count-3 { grid-template-columns: repeat(3, 1fr); }
  .case-metrics--count-4 { grid-template-columns: repeat(2, 1fr); }

  .case-metrics--row .case-metric {
    text-align: left;
  }

  .case-metrics--row .case-metric__value {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.25rem;
    color: var(--accent);
    line-height: 1.2;
    display: block;
    margin-bottom: var(--sp-1);
  }

  .case-metrics--row .case-metric__label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-body);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6);
    margin-top: var(--sp-8);
  }

  @media (max-width: 1024px) {
    .insights-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .insights-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
