---
import PageLayout from "../layouts/PageLayout.astro";
import Button from "../components/ui/Button.astro";
import CTABand from "../components/ui/CTABand.astro";
import Marquee from "../components/ui/Marquee.astro";
import StatBlock from "../components/ui/StatBlock.astro";
import Testimonial from "../components/ui/Testimonial.astro";
import { caseStudies, services } from "../data/company";
import { site } from "../data/site";
import { homeStats } from "../data/stats";

const featuredCase = caseStudies[0];
const featuredServices = services.slice(0, 6);
---

<PageLayout
  title="Corporate Strategy & Stakeholder Advisory"
  description="Duke Strategies helps business leaders build stakeholder-proof strategy at the intersection of corporate strategy, corporate affairs, and communications."
  pathname="/"
  ogImage="/assets/images/Erasmusbrug_zwart.jpg"
>
  <section class="hero">
    <video class="hero__video" autoplay muted loop playsinline poster="/assets/images/Erasmusbrug_zwart.jpg">
      <source src="/assets/video/AquaductHarderwijk_1920x1080px.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>

    <div class="hero__content">
      <img src="/assets/logos/DukeStrategies_logo.svg" alt="" class="hero__logo hero-fade hero-fade-1" aria-hidden="true" />
      <h1 class="hero-fade hero-fade-2">{site.title}</h1>
      <p class="hero__subtitle hero-fade hero-fade-3">
        Duke Strategies is a consultancy that operates on the intersection of corporate strategy and corporate affairs and helps to build bridges between business leaders and their stakeholders.
      </p>
      <Button href="/what-we-do" class="hero-fade hero-fade-4">Discover our approach</Button>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="7 13 12 18 17 13"></polyline>
        <line x1="12" y1="6" x2="12" y2="18"></line>
      </svg>
    </div>
  </section>

  <Marquee items={site.marqueeItems} />

  <section id="about" class="section">
    <div class="container">
      <span class="label animate">About Us</span>
      <h2 class="section-heading animate stagger-1">We make business strategies stakeholder proof</h2>

      <div class="grid grid--7-5 items-start" style="margin-top: var(--sp-8);">
        <div class="animate stagger-2">
          <img
            src="/assets/logos/DukeStrategies_logo_grey.svg"
            alt="Duke Strategies"
            style="width: 160px; margin-bottom: var(--sp-6);"
          />
          <p>
            At Duke Strategies we envision a future where corporations succeed by responding to the evolving needs and interests of all of their stakeholders.
          </p>
          <p>
            Whether they are shareholders, employees, clients, policy makers or the public at large, their acceptance of your business decisions impacts business success. This requires deep data and insights into their drivers, thoughts and actions to craft a business-proof corporate strategy that caters to the needs of all stakeholders.
          </p>
          <p>
            We believe that by successfully bridging the gap between business realities and diverging stakeholder expectations, corporations can deliver more value for all. Supported by tailored stakeholder and communications strategies, real impact can be made.
          </p>
          <Button href="/who-we-are" variant="text" class="mt-6">Meet our team</Button>
        </div>
        <div class="img-cover img-cover--coral animate stagger-3" style="min-height: 400px;">
          <img src="/assets/images/Erasmusbrug_zwart.jpg" alt="Erasmus Bridge, Rotterdam" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </div>
  </section>

  <section class="banner">
    <img src="/assets/images/Nesciobrug.jpg" alt="" class="banner__bg" aria-hidden="true" />
    <div class="banner__overlay"></div>
    <div class="banner__content container" style="padding: var(--sp-10) var(--sp-5);">
      <div style="max-width: 720px;">
        <span class="label animate">Our Philosophy</span>
        <h2 class="animate stagger-1" style="color: #fff;">Stakeholder Advisory</h2>
        <p class="animate stagger-2" style="color: rgba(255,255,255,0.85); font-size: 1.05rem; line-height: 1.8; margin-top: var(--sp-5);">
          We guide companies and their leaders through the complex political, social and business environment of stakeholder perceptions and opinions. Our unique combination of in-house capabilities in corporate strategy, corporate affairs, stakeholder management, data &amp; AI analysis and communications advisory allows us to look beyond the obvious and find
          <span class="highlight"> "The One Thing" </span>
          that makes stakeholders agree and support the course of action defined. Because a strategy that is not communicated is a strategy that will not be executed.
        </p>
      </div>
    </div>
  </section>

  <section class="section--dark section--sm">
    <div class="container">
      <div class="stats">
        {homeStats.map((stat, index) => (
          <StatBlock {...stat} class={`animate stagger-${index + 1}`} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container text-center">
      <span class="label animate">Our Approach</span>
      <h2 class="section-heading animate stagger-1">Analyse, Create &amp; Execute</h2>

      <div class="steps" style="margin-top: var(--sp-9);">
        <div class="step animate stagger-2">
          <div class="step__number">1</div>
          <div class="step__title">Analyse</div>
          <p class="step__text">
            We analyse the intent, capabilities and potential actions of both our clients and stakeholders, based on strategic plans, interviews and advanced AI analysis tools.
          </p>
        </div>
        <div class="step animate stagger-3">
          <div class="step__number">2</div>
          <div class="step__title">Create</div>
          <p class="step__text">
            We explore a Single Most Important Action that becomes the basis for strategy, narrative, and stakeholder alignment. A strategy that cannot be communicated will not be executed.
          </p>
        </div>
        <div class="step animate stagger-4">
          <div class="step__number">3</div>
          <div class="step__title">Execute</div>
          <p class="step__text">
            We help clients execute the actions identified in the plan, from communications strategy to media training, stakeholder engagement and AI-driven analysis.
          </p>
        </div>
      </div>

      <Button href="/what-we-do" class="mt-8 animate stagger-5">Explore our services</Button>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="label animate">What We Do</span>
      <h2 class="section-heading animate stagger-1">Our Expertise</h2>

      <div class="cards-grid" style="margin-top: var(--sp-8);">
        {featuredServices.map((service, index) => (
          <div class={`card animate stagger-${(index % 6) + 1}`}>
            <h4 class="card__title">{service.name}</h4>
            <p class="card__text">{service.description}</p>
            <a href="/what-we-do" class="card__link">Learn more</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="label animate">Case Study</span>

      <div class="grid grid--7-5 items-center" style="margin-top: var(--sp-6);">
        <div class="animate stagger-1">
          <h3 style="text-transform: none; letter-spacing: 0; font-size: 1.5rem; line-height: 1.4;">{featuredCase.title}</h3>
          <p style="margin-top: var(--sp-5);">{featuredCase.shortSummary}</p>

          <div class="case-metrics">
            {featuredCase.metrics.map((metric) => (
              <div class="case-metric">
                <span class="case-metric__value">{metric.value}</span>
                <span class="case-metric__label">{metric.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="img-cover img-cover--coral animate stagger-2" style="min-height: 360px;">
          <img src={featuredCase.image} alt={featuredCase.imageAlt} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <Testimonial quote="When the crisis hit, Duke Strategies did not just manage the media - they helped us understand our entire stakeholder landscape and rebuild trust systematically. Their combination of crisis experience and analytical rigour was exactly what we needed under pressure." author="CEO, European Industrial Group" class="animate" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid--7-5 items-center">
        <div class="animate stagger-1">
          <img
            src="/assets/logos/DukeAcademy_rgb_no_padding.svg"
            alt="Duke Academy"
            style="width: 200px; margin-bottom: var(--sp-5);"
          />
          <h3 style="text-transform: none; letter-spacing: 0; font-size: 1.4rem; line-height: 1.4;">
            AI-Powered Executive Training for Impactful Leadership
          </h3>
          <p style="margin-top: var(--sp-4);">
            Duke Academy delivers immersive, AI-enhanced training programmes designed to equip leaders with the skills to navigate stakeholder complexity, communicate under pressure, and drive strategic outcomes.
          </p>

          <ul class="academy-programs">
            <li>Executive Media Training</li>
            <li>Crisis Simulation &amp; Response</li>
            <li>Stakeholder Engagement Masterclass</li>
            <li>AI-Driven Strategic Communications</li>
          </ul>

          <Button href="/duke-academy" class="mt-6">Discover Duke Academy</Button>
        </div>
        <div class="img-cover img-cover--coral animate stagger-2" style="min-height: 400px;">
          <img src="/assets/images/Pythonbrug_Amsterdam_contrast.jpg" alt="Python Bridge, Amsterdam" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </div>
    </div>
  </section>

  <CTABand
    title="Ready to make your strategy stakeholder-proof?"
    description="Get in touch with Duke Strategies to explore how we can help."
  />
</PageLayout>
