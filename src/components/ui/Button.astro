---
interface Props {
  href: string;
  variant?: "primary" | "outline" | "outline-dark" | "text";
  class?: string;
  target?: string;
  rel?: string;
}

const { href, variant = "primary", class: className = "", target, rel } = Astro.props;
const resolvedRel = target === "_blank" ? rel ?? "noopener noreferrer" : rel;
---

<a href={href} class:list={["btn", `btn--${variant}`, className]} target={target} rel={resolvedRel}>
  <slot />
</a>
