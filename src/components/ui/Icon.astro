const markup = icons[name] ?? "";
---

<span class:list={["icon", className]} aria-hidden="true" set:html={markup}></span>

<style>
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .icon :global(svg) {
    width: 1em;
    height: 1em;
  }
</style>
