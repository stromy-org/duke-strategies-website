---
/**
 * Complete SEO head partial: primary meta + canonical + robots + hreflang +
 * Open Graph + Twitter + one escaped JSON-LD @graph. Site-agnostic — reads
 * brand identity from `site`. Reused by `BaseLayout` and per-site layouts.
 */
// duke-strategies' site.ts carries Localized<string> title/description; this
// layout is always handed a resolved string `description` prop, so view the
// imported site through the SeoSite lens (the Localized fallback never fires at
// runtime here). Only this import line differs from the canonical kit copy.
import { site as rawSite } from "../../data/site";
import {
  absoluteUrl,
  identitySchema,
  personSchema,
  webSiteSchema,
  type JsonLd as JsonLdNode,
  type SeoSite,
} from "../../lib/seo";
const site = rawSite as unknown as SeoSite;
import JsonLd from "./JsonLd.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  canonical?: string;
  noindex?: boolean;
  isHome?: boolean;
  /** Per-page OG locale (e.g. "es_ES", "nl_NL"); defaults to site.locale.
   *  Bilingual sites pass the current page's locale here. */
  locale?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
  };
  alternates?: { hreflang: string; href: string }[];
  jsonLd?: object[];
}

const {
  title,
  description,
  image,
  type = "website",
  canonical,
  noindex = false,
  isHome = false,
  locale,
  article,
  alternates,
  jsonLd = [],
} = Astro.props;

const ogLocale = locale ?? site.locale;

// Dedupe the brand suffix: a page that passes its title === site.name (or
// already ends with the suffix) must not become "Name | Name".
const pageTitle =
  !title || title === site.name || title.endsWith(`| ${site.name}`)
    ? title || site.name
    : `${title} | ${site.name}`;
const pageDescription = description ?? site.description;
const canonicalUrl = canonical
  ? absoluteUrl(canonical, site.url)
  : absoluteUrl(Astro.url.pathname, site.url);

// og:image resolves page image → site default. When neither exists (a site
// that ships no default card) it is omitted rather than emitting a non-image
// URL. width/height are only emitted for the default asset, which the kit
// guarantees is 1200×630; an arbitrary page hero must not be mislabeled.
const resolvedOg = image ?? site.defaultOgImage;
const ogImage = resolvedOg ? absoluteUrl(resolvedOg, site.url) : undefined;
const usingDefaultOg = !image && !!site.defaultOgImage;

// Site-wide identity graph is emitted once, on the homepage (Google guidance).
const baseGraph: JsonLdNode[] = isHome
  ? site.entityType === "Person"
    ? [personSchema(site), webSiteSchema(site)]
    : [identitySchema(site), webSiteSchema(site)]
  : [];

// Combine into a single @graph document (strip per-node @context to the root).
const nodes = [...baseGraph, ...(jsonLd as JsonLdNode[])];
const ldGraph =
  nodes.length > 0
    ? {
        "@context": "https://schema.org",
        "@graph": nodes.map(({ "@context": _ctx, ...rest }) => rest),
      }
    : null;
---
<title>{pageTitle}</title>
{pageDescription && <meta name="description" content={pageDescription} />}
<link rel="canonical" href={canonicalUrl} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{
  alternates?.map((a) => (
    <link rel="alternate" hreflang={a.hreflang} href={a.href} />
  ))
}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={site.name} />
{ogLocale && <meta property="og:locale" content={ogLocale} />}
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={pageTitle} />
{pageDescription && <meta property="og:description" content={pageDescription} />}
{ogImage && <meta property="og:image" content={ogImage} />}
{usingDefaultOg && <meta property="og:image:width" content="1200" />}
{usingDefaultOg && <meta property="og:image:height" content="630" />}

{
  type === "article" && article?.publishedTime && (
    <meta property="article:published_time" content={article.publishedTime} />
  )
}
{
  type === "article" && article?.modifiedTime && (
    <meta property="article:modified_time" content={article.modifiedTime} />
  )
}
{
  type === "article" && article?.author && (
    <meta property="article:author" content={article.author} />
  )
}
{
  type === "article" && article?.section && (
    <meta property="article:section" content={article.section} />
  )
}
{
  type === "article" &&
    article?.tags?.map((t) => <meta property="article:tag" content={t} />)
}

<meta name="twitter:card" content="summary_large_image" />
{site.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
<meta name="twitter:title" content={pageTitle} />
{
  pageDescription && (
    <meta name="twitter:description" content={pageDescription} />
  )
}
{ogImage && <meta name="twitter:image" content={ogImage} />}

{ldGraph && <JsonLd schema={ldGraph} />}
