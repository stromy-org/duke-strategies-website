---
import Icon from "../ui/Icon.astro";
import { navItems } from "../../data/nav";
import { site } from "../../data/site";
import { useTranslations, localizedPath } from "../../i18n/utils";
import { pickLocale, type SupportedLocale } from "../../i18n/pickLocale";

interface Props {
  lang?: SupportedLocale;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <img src="/assets/logos/DukeStrategies_logo_white.png" alt="Duke Strategies" class="footer__logo" />
        <p class="footer__desc">{pickLocale(site.footerDescription, lang)}</p>
      </div>

      <div>
        <h6 class="footer__heading">Office</h6>
        <p style="font-size: 0.9rem; line-height: 1.8;">
          {site.legalName}<br />
          {site.office.street}<br />
          {site.office.postalCode} {site.office.city}<br />
          {site.office.country}
        </p>
      </div>

      <div>
        <h6 class="footer__heading">Sitemap</h6>
        <div class="footer__links">
          {navItems.map((item) => (
            <a href={localizedPath(item.href, lang)}>{t(item.labelKey)}</a>
          ))}
        </div>
      </div>

      <div>
        <h6 class="footer__heading">Contact</h6>
        <div class="footer__contact">
          <p>
            T <a href={site.contact.phoneHref}>{site.contact.phoneDisplay}</a>
          </p>
          <p>
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </p>
        </div>
        <div class="footer__social">
          <a href={site.contact.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <Icon name="linkedin" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bar">
    <div class="container">&copy; 2025 {site.legalName} - All rights reserved</div>
  </div>
</footer>
