{
  "name": "duke-strategies-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run tokens && astro build",
    "preview": "astro preview",
    "tokens": "node --import tsx scripts/generate-tokens.ts",
    "check": "astro check",
    "check:links": "node scripts/check-links.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stromy-org/duke-strategies-website.git"
  },
  "dependencies": {
